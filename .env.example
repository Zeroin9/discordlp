# Discord Bot Token
# Get this from the Discord Developer Portal: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# PostgreSQL Database Connection
# For Docker Compose, use 'db' as the host. For local development, use 'localhost'.
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/discordlp
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your_database_password
